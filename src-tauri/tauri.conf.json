{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "freewrite",
  "version": "0.0.3",
  "identifier": "me.nkdr.freewrite",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "freewrite",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "TAURI_UPDATER_PUBLIC_KEY_SET_BY_RELEASE_SCRIPT",
      "endpoints": [
        "https://github.com/nikitadrokin/freewrite/releases/latest/download/latest.json"
      ]
    }
  }
}
